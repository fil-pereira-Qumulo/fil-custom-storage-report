      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"storage-reporting\")\r\n  |> range(start: -2h)\r\n  |> filter(fn: (r) => r._measurement == \"storage_share_detail\")\r\n  |> filter(fn: (r) => r.cluster == \"${cluster}\")\r\n  |> last()\r\n  |> group()\r\n  |> pivot(rowKey: [\"share_path\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> group()\r\n  |> keep(columns: [\"share_path\", \"type\", \"fs_path\", \"quota_limit\", \"quota_used\", \"owner\", \"team\", \"snow_request\", \"speedtype\"])\r\n  |> rename(columns: {\r\n      share_path:   \"Share Path / NFS Export\",\r\n      type:         \"SMB/NFS\",\r\n      fs_path:      \"Filesystem Path\",\r\n      quota_limit:  \"Quota Allocated\",\r\n      quota_used:   \"Quota Used\",\r\n      owner:        \"Owner\",\r\n      team:         \"Team\",\r\n      snow_request: \"SNOW Request\",\r\n      speedtype:    \"Speedtype\"\r\n  })",
          "refId": "A"
        }
      ],
      "title": "Qumulo Cluster SMB and NFS storage tracking",
      "type": "table"
    }
